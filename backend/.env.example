# backend/.env.example — bu dosya COMMIT EDİLİR (gerçek anahtar içermez).
# Gerçek değerlerle backend/.env oluştur; .env .gitignore'da, commit edilmez.
#
# GEMINI_API_KEY: SADECE eval_golden_roles.py / providers/gemini_provider.py
# için kullanılır (test/eval amaçlı — CLAUDE.md §5/§6, bkz. gemini_provider.py
# modül docstring'i: production hasta verisi için bu YETERLİ DEĞİL).
GEMINI_API_KEY=

# Audio provider seçimi.
# - not_configured: güvenli default; transkript üretmez, ham ses geçici işlenip silinir.
# - dev_fixture: lokal geliştirme; gerçek sesi işlemez, sabit örnek transcript üretir.
# - gemini_audio: demo MVP; gerçek ses dosyasını Gemini ile speaker-labelled transcript'e çevirir.
# - managed_http: gerçek vendor adapter yuvası; aşağıdaki endpoint/key gerekir.
TANDELA_AUDIO_PROVIDER=not_configured
GEMINI_AUDIO_MODEL=gemini-3.5-flash
TANDELA_AUDIO_ENDPOINT_URL=
TANDELA_AUDIO_API_KEY=
TANDELA_AUDIO_REGION=eu
TANDELA_AUDIO_TIMEOUT_SEC=120

# Production'da PostgreSQL URL'i kullanılır.
# Lokal geliştirmede boş bırakılırsa sqlite:///./.tandela_dev.db kullanılır.
DATABASE_URL=

# Auth skeleton.
# dev: header yoksa dev-clinic/dev-doctor kullanır.
# required: X-Tandela-Clinic-Id ve X-Tandela-User-Id zorunlu olur.
TANDELA_AUTH_MODE=dev
